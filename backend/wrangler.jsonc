{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "membership-app-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-31",
  "account_id": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
  "d1_databases": [
    {
      "binding": "MEMBERS_DB",
      "database_name": "membership-app-database",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "remote": true,
      "migrations_dir": "../database/members"
    },
    {
      "binding": "VMS_DB",
      "database_name": "vms-database",
      "database_id": "00000000-0000-0000-0000-000000000001",
      "remote": true,
      "migrations_dir": "../database/vms"
    },
    {
      "binding": "VMS_LOGS_DB",
      "database_name": "vms-logs-database",
      "database_id": "00000000-0000-0000-0000-000000000002",
      "remote": true,
      "migrations_dir": "../database/logs"
    }
  ],
  "triggers": {
    "crons": ["*/15 4-18 * * *"]
  },
  "r2_buckets": [
    {
      "binding": "MY_BUCKET",
      "bucket_name": "membership-app-bucket",
      "remote": true
    }
  ],
  "services": [
    {
      "binding": "TELEGRAM_MS_SERVICE",
      "service": "telegram-ms",
      "remote": true
    }
  ],
  "vars": {
    "MEMBERSHIP_NUMBER_PREFIX": "2501",
    "TELEGRAM_MS":"https://ibtikar.tr/ms/telegram",
    "FRONTEND_BASE_URL":"https://ibtikar.tr",
    "INTERNAL_SECRET":"delete-on-deployment",
    "SMTP_HOST": "",
    "SMTP_PORT": "587",
    "SMTP_USER": "",
    "SMTP_PASS": "delete-on-deployment",
    "CRON_TIMEZONE": "Europe/Istanbul",
    "CRON_DRY_RUN": "false"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}