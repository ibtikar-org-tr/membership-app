{
  "name": "telegram-ms",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:local": "wrangler dev --config wrangler.local.jsonc",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply telegram-ms-database --local",
    "db:migrate:remote": "wrangler d1 migrations apply telegram-ms-database --remote"
  },
  "dependencies": {
    "hono": "^4.12.14",
    "worker-mailer": "^1.2.1"
  },
  "devDependencies": {
    "wrangler": "^4.4.0"
  }
}
