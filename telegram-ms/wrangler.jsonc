{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vms-telegram-ms",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-15",
  "account_id": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
  "d1_databases": [
    {
      "binding": "TELEGRAM_DB",
      "database_name": "telegram-ms-database",
      "database_id": "00000000-0000-0000-0000-000000000004",
      "remote": true,
      "migrations_dir": "../database/telegram"
    },
    {
      "binding": "TELEGRAM_MESSAGES_DB",
      "database_name": "telegram-messages-database",
      "database_id": "00000000-0000-0000-0000-000000000005",
      "remote": true,
      "migrations_dir": "../database/telegram-messages"
    },
    {
      "binding": "MEMBERS_DB",
      "database_name": "membership-app-database",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "remote": true
    }
  ],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "vars": {
    "MAIN_CHANNEL": "ibtikar_org",
    "SMTP_HOST": "",
    "SMTP_PORT": "587",
    "SMTP_USER": "",
    "SMTP_PASS": "delete-on-deployment",
    "TELEGRAM_MS": "https://ibtikar.tr/ms/telegram",
    "TELEGRAM_BOT_TOKEN": "delete-on-deployment",
    "INTERNAL_SECRET":"delete-on-deployment",
    "DEEPSEEK_API_KEY":"delete-on-deployment"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}